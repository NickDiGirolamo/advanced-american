{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blog/[slug]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/business-insurance/[slug]",
      "regex": "^/business\\-insurance/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/business\\-insurance/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/personal-insurance/[slug]",
      "regex": "^/personal\\-insurance/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/personal\\-insurance/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/service-center/[requestType]",
      "regex": "^/service\\-center/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPrequestType": "nxtPrequestType"
      },
      "namedRegex": "^/service\\-center/(?<nxtPrequestType>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/about/companies",
      "regex": "^/about/companies(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about/companies(?:/)?$"
    },
    {
      "page": "/about/independent-agent",
      "regex": "^/about/independent\\-agent(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about/independent\\-agent(?:/)?$"
    },
    {
      "page": "/about/staff",
      "regex": "^/about/staff(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about/staff(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/business-insurance",
      "regex": "^/business\\-insurance(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/business\\-insurance(?:/)?$"
    },
    {
      "page": "/claims",
      "regex": "^/claims(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/claims(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/payments",
      "regex": "^/payments(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/payments(?:/)?$"
    },
    {
      "page": "/personal-insurance",
      "regex": "^/personal\\-insurance(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/personal\\-insurance(?:/)?$"
    },
    {
      "page": "/quotes",
      "regex": "^/quotes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/quotes(?:/)?$"
    },
    {
      "page": "/referrals",
      "regex": "^/referrals(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/referrals(?:/)?$"
    },
    {
      "page": "/service-center",
      "regex": "^/service\\-center(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/service\\-center(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
